# LifeGranted Adventures — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Flutterwave handles all payments — international cards and mobile money
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (email)
RESEND_API_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Platform
NEXT_PUBLIC_PLATFORM_NAME=LifeGranted Adventures
NEXT_PUBLIC_SITE_URL=https://lifegrantedadventures.co.tz
NEXT_PUBLIC_PLATFORM_EMAIL=hello@lifegrantedadventures.co.tz
NEXT_PUBLIC_PLATFORM_WHATSAPP=+255000000000
NEXT_PUBLIC_PLATFORM_COMMISSION=0.12
PLATFORM_ADMIN_EMAIL=stephen@lifegrantedadventures.co.tz
CRON_SECRET=
